{
  "name": "hurlman",
  "version": "0.1.0",
  "description": "Thin CLI wrapper around hurl with env composition and computed-variable injection.",
  "license": "MIT",
  "keywords": [
    "hurl",
    "http",
    "api",
    "testing",
    "cli"
  ],
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "hurlman": "./dist/index.js"
  },
  "types": "./dist/types.d.ts",
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "postbuild": "chmod +x dist/index.js",
    "prepublishOnly": "npm run build",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "commander": "^13.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  }
}
